# ─────────────────────────────────────────────────────────────────────────────
# AMIRI GEMS — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL / phpMyAdmin) ─────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Example for local phpMyAdmin / XAMPP / WAMP:
DATABASE_URL="mysql://root:@localhost:3306/amiri_gems"
# Example with password:
# DATABASE_URL="mysql://root:yourpassword@localhost:3306/amiri_gems"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: run `openssl rand -base64 32` in terminal
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── Upload Settings ───────────────────────────────────────────────────────────
# Max file size in MB
MAX_FILE_SIZE=10
UPLOAD_DIR="public/uploads"

# ── App Settings ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Amiri Gems"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Future: S3 / Cloudinary (leave empty for now) ────────────────────────────
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""
