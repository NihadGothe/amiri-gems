generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          Role      @default(EDITOR)
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Brand {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  type             BrandType
  shortDescription String?   @db.Text
  fullDescription  String?   @db.LongText
  logo             String?
  heroImages       String?   @db.LongText
  galleryImages    String?   @db.LongText
  status           Boolean   @default(true)
  sortOrder        Int       @default(0)
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  products         Product[]

  @@map("brands")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  bannerImage String?
  status      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)
  products    Product[]

  @@map("categories")
}

model Product {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  brandId          String
  categoryId       String?
  type             BrandType
  shortDescription String?   @db.Text
  fullDescription  String?   @db.LongText
  images           String?   @db.LongText
  price            Decimal?  @db.Decimal(10, 2)
  salePrice        Decimal?  @db.Decimal(10, 2)
  sku              String?   @unique
  stock            Int?      @default(0)
  specifications   String?   @db.LongText
  isFeatured       Boolean   @default(false)
  isPublished      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  brand            Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category         Category? @relation(fields: [categoryId], references: [id])

  @@index([brandId], map: "products_brandId_fkey")
  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model Event {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  date             DateTime
  location         String?
  shortDescription String?  @db.Text
  fullDescription  String?  @db.LongText
  mainImage        String?
  galleryImages    String?  @db.LongText
  isFeatured       Boolean  @default(false)
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isDeleted        Boolean  @default(false)

  @@map("events")
}

model Boutique {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  city          String?
  country       String?
  address       String?  @db.Text
  phone         String?
  email         String?
  whatsapp      String?
  openingHours  String?  @db.LongText
  latitude      Float?
  longitude     Float?
  brands        String?  @db.LongText
  services      String?  @db.LongText
  galleryImages String?  @db.LongText
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
  sortOrder     Int?     @default(0)

  @@map("boutiques")
}

model Slider {
  id        String     @id @default(cuid())
  title     String?
  subtitle  String?
  image     String
  ctaText   String?
  ctaLink   String?
  placement SliderPage
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isDeleted Boolean    @default(false)

  @@map("sliders")
}

model Media {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  type        MediaType
  image       String?
  videoUrl    String?
  description String?   @db.Text
  date        DateTime?
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)
  sourceUrl   String?   @db.VarChar(500)

  @@map("media")
}

model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  content   String?  @db.LongText
  image     String?
  metadata  String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_blocks")
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contact_messages")
}

enum Role {
  SUPER_ADMIN
  EDITOR
}

enum BrandType {
  JEWELLERY
  WATCH
}

enum SliderPage {
  HOME
  JEWELLERY
  WATCHES
  BRANDS
  EVENTS
  MEDIA
}

enum MediaType {
  NEWS
  MAGAZINE
  EXHIBITION
  TV_COMMERCIAL
  PRESS
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}
